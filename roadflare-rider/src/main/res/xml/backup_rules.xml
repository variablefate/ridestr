<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <exclude domain="sharedpref" path="roadflare_secure_keys.xml" />
    <exclude domain="sharedpref" path="roadflare_ride_session.xml" />
    <exclude domain="sharedpref" path="roadflare_settings.xml" />
