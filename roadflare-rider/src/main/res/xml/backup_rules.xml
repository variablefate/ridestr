    <exclude domain="sharedpref" path="roadflare_ride_history.xml" />
    <exclude domain="sharedpref" path="roadflare_saved_locations.xml" />
    <exclude domain="sharedpref" path="roadflare_vehicles.xml" />
    <exclude domain="sharedpref" path="roadflare_followed_drivers.xml" />
    <exclude domain="sharedpref" path="roadflare_driver_state.xml" />
